# Copy to .env.local and fill in. Never commit real keys (.env* is gitignored).
# Load into a shell with:  export $(grep -v '^#' .env.local | xargs)

# --- Required for live model runs (uplift + baseline) ----------------------
# HUD inference gateway: routes policy generation (Gemma-4, Claude, etc.) and
# runs hosted evals. Get/rotate at https://app.hud.ai. Used by:
#   cologic/uplift_run.py, agents/run_loop.py, hud eval/deploy/sync.
HUD_API_KEY=

# --- Required only for the GRPO training flywheel (Phase 3) -----------------
# Fireworks: open-weights policy generation + RL fine-tune. Used by:
#   cologic/inference.py (_client), agents/train.py.
FIREWORKS_API_KEY=
# Optional overrides:
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# RLHDL_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct

# --- Optional ---------------------------------------------------------------
# Only if billing the eval agent to your own Anthropic credits instead of HUD's.
# ANTHROPIC_API_KEY=
# Model the uplift/loop policy uses through the HUD gateway (Gemma-4 by default
# for the trainable open-weights story; matches the demo's 'gem' column).
# COLOGIC_DOER=gemma-4-31b-it
# HUD_GATEWAY_URL=https://inference.beta.hud.ai/v1
